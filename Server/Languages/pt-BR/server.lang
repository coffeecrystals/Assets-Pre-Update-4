items.Ingredient_Bar_Adamantite.name = Lingote de Adamantita
items.Ingredient_Bar_Adamantite.description = <item is="Ore_Adamantite"/> requer uma picareta de alta qualidade para ser quebrado.\n\n<i>Este metal raro foi essencial para os avanços feitos pelos povos de Crucible. Embora pouco reste do antigo esplendor da cidade, vestígios deste resistente minério ainda podem ser encontrados nas profundezas sob aquelas terras queimadas.</i>
items.Ingredient_Bar_Bronze.name = Lingote de Bronze
items.Ingredient_Bar_Cobalt.name = Lingote de Cobalto
items.Ingredient_Bar_Cobalt.description = <i>Nos mitos dos Outlanders, se diz que este metal é frio ao toque, mesmo quando está fundido. Embora comprovar isso não seja nada recomendável, suas origens entre os picos gelados e cavernas congeladas de seu território dão algum crédito à história.</i>
items.Ingredient_Bar_Copper.name = Lingote de Cobre
items.Ingredient_Bar_Copper.description = Um metal comum fundido a partir de minérios encontrados em todas as regiões de Orbis.
items.Ingredient_Bar_Gold.name = Lingote de Ouro
items.Ingredient_Bar_Iron.name = Lingote de Ferro
items.Ingredient_Bar_Iron.description = Sua abundância natural e resistência confiável fazem deste metal a escolha ideal para criar ferramentas e armas comuns.
items.Ingredient_Bar_Mithril.name = Lingote de Mithril
items.Ingredient_Bar_Onyxium.name = Lingote de Oníxio
items.Ingredient_Bar_Prisma.name = Lingote de Prisma
items.Ingredient_Bar_Silver.name = Lingote de Prata
items.Ingredient_Bar_Thorium.name = Lingote de Tório
items.Ingredient_Bar_Thorium.description = <i>Embora os Ferans não façam uso direto deste metal, eles mantêm vigilância constante sobre seus depósitos nos desertos abrasados pelo sol e nas terras áridas. Caso seus inimigos ancestrais retornem, essas reservas seriam as primeiras a serem exploradas.</i>
items.Ingredient_Bolt_Cindercloth.name = Rolo de Brasatrama
items.Ingredient_Bolt_Cotton.name = Rolo de Algodão
items.Ingredient_Bolt_Linen.name = Rolo de Linho
items.Ingredient_Bolt_Prismaloom.name = Rolo de Prismatrama
items.Ingredient_Bolt_Shadoweave.name = Rolo de Umbratrama
items.Ingredient_Bolt_Silk.name = Rolo de Seda
items.Ingredient_Bolt_Stormsilk.name = Rolo de Tempesseda
items.Ingredient_Bolt_Wool.name = Rolo de Lã
items.Ingredient_Bone_Fragment.name = Fragmentos de Ossos
items.Ingredient_Bone_Fragment.description = <i>As civilizações mais avançadas de Orbis compartilhavam uma característica em comum: a arrogância — e foi ela que acabou por conduzi-las à ruína. Estes fragmentos de ossos, e a criatura amaldiçoada da qual foram retirados, devem servir como um lembrete de que alguns caminhos não devem ser trilhados.</i>
items.Ingredient_Charcoal.name = Carvão Vegetal

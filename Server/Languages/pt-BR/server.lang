items.Ingredient_Fabric_Scrap_Cindercloth.name = Retalhos de Brasatrama
items.Ingredient_Fabric_Scrap_Cindercloth.description = <i>Quando a chama amaldiçoada devastou Crucible, nada permaneceu igual. Até mesmo estes retalhos de tecido, recuperados dos ossos carbonizados de um antigo habitante, continuam a emitir um calor inquietante.</i>
items.Ingredient_Fabric_Scrap_Cotton.name = Retalhos de Algodão
items.Ingredient_Fabric_Scrap_Linen.name = Retalhos de Linho
items.Ingredient_Fabric_Scrap_Linen.description = Retalhos de um tecido comum usado por muitas espécies de Orbis para confeccionar suas roupas.
items.Ingredient_Fabric_Scrap_Prismaloom.name = Retalhos de Prismatrama
items.Ingredient_Fabric_Scrap_Shadoweave.name = Retalhos de Umbratrama
items.Ingredient_Fabric_Scrap_Shadoweave.description = <i>Este tecido pesado, impregnado por uma escuridão silenciosa e opressiva, foi concebido pelos Outlanders antes de sua primeira comunhão com o Vazio. Embora ainda seja um elemento central de suas roupas, o segredo de sua confecção perdeu-se há muito tempo.</i>
items.Ingredient_Fabric_Scrap_Silk.name = Retalhos de Seda
items.Ingredient_Fabric_Scrap_Stormsilk.name = Retalhos de Tempesseda
items.Ingredient_Fabric_Scrap_Wool.name = Retalhos de Lã

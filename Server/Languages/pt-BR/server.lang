items.PortalKey_Windsurf_Valley.name = Fragmento: Orbis — Vale dos Cavaleiros do Vento
items.PortalKey_Windsurf_Valley.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Um Feran valoriza, acima de tudo, a liberdade, e em nenhum lugar essa liberdade é mais evidente do que no Vale dos Cavaleiros do Vento.</i>
items.PortalKey_Jungles.name = Fragmento: Orbis — Refúgio de Tal'Kesi
items.PortalKey_Jungles.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Nas profundezas das terras devastadas por uma civilização antiga, prospera um refúgio primordial.</i>
items.PortalKey_Taiga.name = Fragmento: Orbis — Taiga do Pico do Dragão
items.PortalKey_Taiga.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Existem florestas congeladas onde nem mesmo um Outlander ousa pisar, não importa o quanto os sussurros o chamem.</i>
items.PortalKey_Hederas_Lair.name = Fragmento: Orbis — O Temido Pântano
items.PortalKey_Hederas_Lair.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Poucos enfrentaram os horrores que espreitam nas profundezas mais sombrias de Orbis.</i>
items.PortalKey_Henges.name = Fragmento: Orbis — Henges Silenciosos
items.PortalKey_Henges.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Misteriosos monumentos de pedra se erguem sobre uma terra congelada.</i>
items.Portal_Device.name = Portal Ancestral
items.Portal_Device.description = Coloque isto na sua base para derrubar as barreiras e viajar para outros Fragmentos!<i>\nEm desenvolvimento\n\nEmbora a maldição mantenha a Orbis de Gaia aprisionada, há maneiras de perfurar o Vazio que a envolve.</i>

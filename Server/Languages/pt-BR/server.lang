items.Ingredient_Leather_Heavy.name = Couro Pesado
items.Ingredient_Leather_Heavy.description = Processado a partir das peles espessas de superpredadores.\n\n<i>Todo caçador sonha em derrubar criaturas conhecidas apenas pelos mitos. Com exceção de alguns poucos que se uniram na era dos heróis, a maioria precisa se contentar com ursos, lobos e outros superpredadores.</i>
items.Ingredient_Leather_Light.name = Couro Leve
items.Ingredient_Leather_Light.description = Processado a partir das peles de presas comuns encontradas pela natureza.
items.Ingredient_Leather_Medium.name = Couro Médio
items.Ingredient_Leather_Medium.description = Processado a partir das peles resilientes de ameaças de tamanho médio e bestas blindadas.
items.Ingredient_Leather_Prismic.name = Couro Prismático
items.Ingredient_Leather_Scaled.name = Couro Escamado
items.Ingredient_Leather_Soft.name = Couro Macio

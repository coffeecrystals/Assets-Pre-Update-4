items.Ingredient_Bar_Adamantite.name = Адамантитовий злиток
items.Ingredient_Bar_Adamantite.description = <item is="Ore_Adamantite" displayName="Адамантитова руда"/> потребує високоякісного кайла для видобутку.\n\n<i>Цей рідкісний метал колись відіграв ключову роль у звершеннях народів Крусібла. Хоча від колишньої величі міста майже нічого не лишилося, сліди цієї міцної руди досі можна знайти в глибинах під випаленими землями.</i>
items.Ingredient_Bar_Bronze.name = Бронзовий злиток
items.Ingredient_Bar_Cobalt.name = Кобальтовий злиток
items.Ingredient_Bar_Cobalt.description = <i>Перекази чужоземців мовлять, що цей метал холодний, мов лід, навіть у розплаві. Пересвідчуватись у цьому — справа нерозважна, проте походження металу серед засніжених круч та промерзлих печер дає підстави вірити цим оповідкам.</i>
items.Ingredient_Bar_Copper.name = Мідний злиток
items.Ingredient_Bar_Copper.description = Поширений метал, витоплений із руди, що зустрічається по всіх регіонах Орбісу.
items.Ingredient_Bar_Gold.name = Золотий злиток
items.Ingredient_Bar_Iron.name = Залізний злиток
items.Ingredient_Bar_Iron.description = Його розповсюдженість у природі та надійна міцність роблять цей матеріал ідеальним для виготовлення повсякденних інструментів і зброї.
items.Ingredient_Bar_Mithril.name = Мітриловий злиток
items.Ingredient_Bar_Onyxium.name = Оніксовий злиток
items.Ingredient_Bar_Prisma.name = Призматичний злиток
items.Ingredient_Bar_Silver.name = Срібний злиток
items.Ingredient_Bar_Thorium.name = Торієвий злиток
items.Ingredient_Bar_Thorium.description = <i>Хоч ферани й не використовують цей метал самі, вони пильно стежать за його покладами у випалених сонцем пустелях і посушливих пустирях. Якщо їхні віковічні вороги колись постануть знову, саме ці запаси вони спробують здобути першими.</i>
items.Ingredient_Bolt_Cindercloth.name = Згорток жаристого полотна

                "Jitter": 0.75,
                "Density": [0.40, 0.625]
              }
            }
          ],
          "Normalize": 0.4
        }
      ]
    },
    {
      "$Comment": "Zone 4 Monuments_Dungeon_Challenge",
      "Type": "MIN",
      "Noise": [
        {
          "File": "Zones.Noise.Zone4.Grids.Monuments_Tier5_Dungeon_Challenge"
